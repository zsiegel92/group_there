{
  "name": "groupthere",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"pnpm run python:dev\" \"pnpm run next:dev\"",
    "dev:stage": "concurrently \"pnpm run python:stage\" \"pnpm run next:stage\"",
    "next:dev": "GROUPTHERE_SOLVER_API_URL=http://localhost:8000 next dev",
    "next:stage": "next dev",
    "next:prod-python": "dotenv -e .env -- sh -c 'GROUPTHERE_SOLVER_API_URL=$PRODUCTION_GROUPTHERE_SOLVER_API_URL next dev'",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "python:type-check": "uv run --directory src/solver ty check",
    "python:lint": "uv run --directory src/solver ruff check",
    "python:format": "uv run --directory src/solver ruff format --check",
    "python:format-fix": "uv run --directory src/solver ruff format",
    "python:test": "uv run --directory src/solver/tests pytest",
    "python:test-server": "uv run --directory src/solver modal run server.py",
    "python:check-all": "pnpm run python:type-check && pnpm run python:lint && pnpm run python:format && pnpm run python:test",
    "python:dev": "uv run --directory src/solver uvicorn server:webapp --reload --port 8000",
    "python:dev2": "uv run --directory src/solver fastapi run server.py --reload --port 8000",
    "python:stage": "uv run --directory src/solver modal serve server.py",
    "python:deploy": "uv run --directory src/solver modal deploy server.py",
    "python:dump-openapi": "src/solver/.venv/bin/python src/solver/dump_openapi.py",
    "generate-openapi-ts-from-openapi-json": "openapi-ts",
    "gen-client": "src/solver/.venv/bin/python src/solver/dump_openapi.py && openapi-ts"
  },
  "dependencies": {
    "next": "16.1.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "0.89.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "concurrently": "^9",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
